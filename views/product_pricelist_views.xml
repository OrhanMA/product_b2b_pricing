<odoo>
    <record id="product_pricelist_form_inherit_b2b_pricing" model="ir.ui.view">
        <field name="name">product.pricelist.form.inherit.b2b.pricing</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id']" position="after">
                <field name="product_b2b_pricelist"/>
            </xpath>
        </field>
    </record>
</odoo>
